{
  "name": "vanilla-ts",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "bun index.html",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build ./index.html --outdir=dist --minify",
    "build:inline": "bun build --compile ./index.html --outdir=dist --minify"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "bun-create": {
    "postinstall": "echo '\\n🐰 All set! Run these commands:\\n\\n  bun run dev     → start dev server\\n  bun test        → run tests\\n  bun test --watch → tests in watch mode\\n'"
  }
}
